      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "eewg7p4l9bcaod"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH base AS (\r\n  SELECT\r\n    time,\r\n    meter_name,\r\n    CASE\r\n      WHEN\r\n        COALESCE(v_r_ph_fault, 0) = 1 OR COALESCE(v_y_ph_fault, 0) = 1 OR COALESCE(v_b_ph_fault, 0) = 1 OR\r\n        COALESCE(a_r_ph_fault, 0) = 1 OR COALESCE(a_y_ph_fault, 0) = 1 OR COALESCE(a_b_ph_fault, 0) = 1 OR\r\n        COALESCE(pf_ave_fault, 0) = 1 OR COALESCE(frequency_fault, 0) = 1 OR\r\n        COALESCE(v_r_harmonics_fault, 0) = 1 OR COALESCE(v_y_harmonics_fault, 0) = 1 OR COALESCE(v_b_harmonics_fault, 0) = 1 OR\r\n        COALESCE(a_r_harmonics_fault, 0) = 1 OR COALESCE(a_y_harmonics_fault, 0) = 1 OR COALESCE(a_b_harmonics_fault, 0) = 1 OR\r\n        COALESCE(watts_total_fault, 0) = 1\r\n      THEN 1\r\n      ELSE 0\r\n    END AS is_fault,\r\n    -- ...existing code for fault_groups...\r\n    COALESCE(\r\n      NULLIF(\r\n        TRIM(BOTH ', ' FROM\r\n          CONCAT(\r\n            CASE WHEN COALESCE(v_r_ph_fault, 0) = 1 OR COALESCE(v_y_ph_fault, 0) = 1 OR COALESCE(v_b_ph_fault, 0) = 1 THEN 'Voltage Fault, ' ELSE '' END,\r\n            CASE WHEN COALESCE(a_r_ph_fault, 0) = 1 OR COALESCE(a_y_ph_fault, 0) = 1 OR COALESCE(a_b_ph_fault, 0) = 1 THEN 'Current Fault, ' ELSE '' END,\r\n            CASE WHEN COALESCE(pf_ave_fault, 0) = 1 THEN 'Power Factor Fault, ' ELSE '' END,\r\n            CASE WHEN COALESCE(frequency_fault, 0) = 1 THEN 'Frequency Fault, ' ELSE '' END,\r\n            CASE WHEN COALESCE(v_r_harmonics_fault, 0) = 1 OR COALESCE(v_y_harmonics_fault, 0) = 1 OR COALESCE(v_b_harmonics_fault, 0) = 1 OR COALESCE(a_r_harmonics_fault, 0) = 1 OR COALESCE(a_y_harmonics_fault, 0) = 1 OR COALESCE(a_b_harmonics_fault, 0) = 1 THEN 'Harmonics Fault, ' ELSE '' END,\r\n            CASE WHEN COALESCE(watts_total_fault, 0) = 1 THEN 'Power Fault, ' ELSE '' END\r\n          )\r\n        ),\r\n        ''\r\n      ),\r\n      'OK'\r\n    ) AS fault_groups\r\n  FROM meter_fault_log\r\n  WHERE $__timeFilter(time)\r\n)\r\nSELECT\r\n  time,\r\n  meter_name,\r\n  CASE\r\n    WHEN max(is_fault) OVER (PARTITION BY meter_name ORDER BY time ASC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) = 1 THEN 'Fault'\r\n    ELSE 'OK'\r\n  END AS status,\r\n  fault_groups\r\nFROM base\r\nORDER BY meter_name, time ASC;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [
                  {
                    "name": "\"time\"",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              },
              {
                "parameters": [
                  {
                    "name": "v_r_ph_fault",
                    "type": "functionParameter"
                  }
                ],
                "type": "function"
              }
            ],
            "groupBy": [
