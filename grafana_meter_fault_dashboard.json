      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "eewg7p4l9bcaod"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_faults AS (\r\n  SELECT DISTINCT ON (meter_name)\r\n    meter_name, time, v_r_ph_fault, v_y_ph_fault, v_b_ph_fault,\r\n    a_r_ph_fault, a_y_ph_fault, a_b_ph_fault,\r\n    pf_ave_fault, frequency_fault,\r\n    v_r_harmonics_fault, v_y_harmonics_fault, v_b_harmonics_fault,\r\n    a_r_harmonics_fault, a_y_harmonics_fault, a_b_harmonics_fault,\r\n    watts_total_fault\r\n  FROM meter_fault_log\r\n  WHERE $__timeFilter(time)\r\n  ORDER BY meter_name, time DESC\r\n)\r\nSELECT\r\n  'Meter ' || split_part(mfl.meter_name, '.', 2) AS meter_label,\r\n  mr.location,\r\n  CASE\r\n    WHEN\r\n      GREATEST(\r\n        COALESCE(mfl.v_r_ph_fault, 0), COALESCE(mfl.v_y_ph_fault, 0), COALESCE(mfl.v_b_ph_fault, 0),\r\n        COALESCE(mfl.a_r_ph_fault, 0), COALESCE(mfl.a_y_ph_fault, 0), COALESCE(mfl.a_b_ph_fault, 0),\r\n        COALESCE(mfl.pf_ave_fault, 0), COALESCE(mfl.frequency_fault, 0),\r\n        COALESCE(mfl.v_r_harmonics_fault, 0), COALESCE(mfl.v_y_harmonics_fault, 0), COALESCE(mfl.v_b_harmonics_fault, 0),\r\n        COALESCE(mfl.a_r_harmonics_fault, 0), COALESCE(mfl.a_y_harmonics_fault, 0), COALESCE(mfl.a_b_harmonics_fault, 0),\r\n        COALESCE(mfl.watts_total_fault, 0)\r\n      ) = 1 THEN 1\r\n    ELSE 0\r\n  END AS status,\r\n  TRIM(BOTH ', ' FROM\r\n    CONCAT(\r\n      CASE WHEN GREATEST(COALESCE(mfl.v_r_ph_fault, 0), COALESCE(mfl.v_y_ph_fault, 0), COALESCE(mfl.v_b_ph_fault, 0)) = 1 THEN 'Voltage Fault, ' ELSE '' END,\r\n      CASE WHEN GREATEST(COALESCE(mfl.a_r_ph_fault, 0), COALESCE(mfl.a_y_ph_fault, 0), COALESCE(mfl.a_b_ph_fault, 0)) = 1 THEN 'Current Fault, ' ELSE '' END,\r\n      CASE WHEN COALESCE(mfl.pf_ave_fault, 0) = 1 THEN 'Power Factor Fault, ' ELSE '' END,\r\n      CASE WHEN COALESCE(mfl.frequency_fault, 0) = 1 THEN 'Frequency Fault, ' ELSE '' END,\r\n      CASE WHEN GREATEST(\r\n        COALESCE(mfl.v_r_harmonics_fault, 0), COALESCE(mfl.v_y_harmonics_fault, 0), COALESCE(mfl.v_b_harmonics_fault, 0),\r\n        COALESCE(mfl.a_r_harmonics_fault, 0), COALESCE(mfl.a_y_harmonics_fault, 0), COALESCE(mfl.a_b_harmonics_fault, 0)\r\n      ) = 1 THEN 'Harmonics Fault, ' ELSE '' END,\r\n      CASE WHEN COALESCE(mfl.watts_total_fault, 0) = 1 THEN 'Power Fault, ' ELSE '' END\r\n    )\r\n  ) AS faults,\r\n  10.975588 + 0.01 * SIN(2 * PI() * (ROW_NUMBER() OVER (ORDER BY mfl.meter_name)-1) / (SELECT COUNT(*) FROM latest_faults)) AS latitude,\r\n  76.737517 + 0.01 * COS(2 * PI() * (ROW_NUMBER() OVER (ORDER BY mfl.meter_name)-1) / (SELECT COUNT(*) FROM latest_faults)) AS longitude\r\nFROM latest_faults mfl\r\nLEFT JOIN LATERAL (\r\n  SELECT location\r\n  FROM meterreadings\r\n  WHERE meter_name = mfl.meter_name\r\n  ORDER BY time DESC\r\n  LIMIT 1\r\n) mr ON TRUE",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Elmeasure Meter Statuses",
      "type": "geomap"
    },
