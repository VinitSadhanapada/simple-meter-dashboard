# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# =============================================================================
# DJANGO CONFIGURATION
# =============================================================================

# Secret key for Django (generate new one for production!)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-change-in-production

# Debug mode (MUST be False in production!)
DEBUG=True

# Allowed hosts (comma-separated, no spaces)
# Development: localhost,127.0.0.1
# Production: yourdomain.com,yourserver-ip
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database engine (postgresql or sqlite)
DB_ENGINE=postgresql

# PostgreSQL connection details
DB_HOST=192.168.112.106
DB_PORT=5432
DB_NAME=mfmdb
DB_USER=mfmuser
DB_PASSWORD=your-database-password-here

# =============================================================================
# SECURITY & ENCRYPTION
# =============================================================================

# Field encryption key (32 url-safe base64 bytes)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# =============================================================================
# EMAIL / SMTP CONFIGURATION (for alerts)
# =============================================================================

# SMTP server settings
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587

# SMTP credentials
# For Gmail, use App Password: https://support.google.com/accounts/answer/185833
ALERT_SMTP_USER=your-email@gmail.com
ALERT_SMTP_PASS=your-app-specific-password

# Email addresses
ALERT_FROM=your-email@gmail.com
ALERT_TO=recipient-email@gmail.com

# =============================================================================
# REDIS CONFIGURATION (for real-time alerts & caching)
# =============================================================================

# Redis connection URL
# Local: redis://localhost:6379/0
# Docker: redis://host.docker.internal:6379/0
# With password: redis://:password@host:6379/0
REDIS_URL=redis://host.docker.internal:6379/0

# Celery broker (usually same as Redis)
CELERY_BROKER_URL=redis://host.docker.internal:6379/0
CELERY_RESULT_BACKEND=redis://host.docker.internal:6379/0

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Device configuration export directory
# Default: /app/device_config_exports (in Docker)
DEVICE_CONFIG_EXPORT_DIR=/app/device_config_exports

# Alert dispatch (0=disabled, 1=enabled)
DISABLE_ALERT_DISPATCH=0

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================

# Grafana admin credentials (change on first login!)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Grafana SMTP settings (uses same as above)
GF_SMTP_ENABLED=true
GF_SMTP_HOST=${ALERT_SMTP_HOST}
GF_SMTP_USER=${ALERT_SMTP_USER}
GF_SMTP_PASSWORD=${ALERT_SMTP_PASS}
GF_SMTP_FROM_ADDRESS=${ALERT_FROM}

# =============================================================================
# NOTES
# =============================================================================

# 1. After copying to .env, replace all placeholder values
# 2. Never commit .env to version control
# 3. Use strong passwords (16+ characters, mixed case, numbers, symbols)
# 4. Rotate secrets regularly (monthly for production)
# 5. Different environments should have different keys and passwords
# 6. For production, consider using a secrets management service
#    (HashiCorp Vault, AWS Secrets Manager, etc.)

# =============================================================================
# QUICK SETUP COMMANDS
# =============================================================================

# 1. Copy this template:
#    cp .env.example .env

# 2. Generate SECRET_KEY:
#    python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# 3. Generate FIELD_ENCRYPTION_KEY:
#    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# 4. Edit .env with your actual values:
#    nano .env

# 5. Start application:
#    docker-compose up -d
