
#1. Install Mosquitto MQTT Broker

offline_rpi_dashboard_db.py --install
#Will install the Mosquitto MQTT broker offline.


#2. Start and Enable Mosquitto Service

sudo systemctl start mosquitto
sudo systemctl enable mosquitto


#3. Check if Mosquitto is Running

sudo systemctl status mosquitto



#5. (Optional) Enable Authentication
#Edit the Mosquitto config file:

sudo vi /etc/mosquitto/conf.d/default.conf

#6. Add

listener 1883 0.0.0.0
allow_anonymous false
password_file /etc/mosquitto/passwd

$7. Create a password file and user:

sudo mosquitto_passwd -c /etc/mosquitto/passwd myuser



#Enter your password when prompted.
#Restart Mosquitto:

sudo systemctl restart mosquitto


#6. Test with Credentials
#SUBCRIBE and test if the data is being available for the the topic/

mosquitto_sub -h localhost -t test/topic -u myuser -P <PASSWD>
